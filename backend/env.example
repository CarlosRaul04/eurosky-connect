# Copia este archivo como .env y coloca tus valores reales.
# NUNCA subas el .env real al repositorio.
PORT=3000

# Clave de Google Maps Platform (Geocoding, Routes, Maps JS).
# Si se deja vacia, mapsService usa el modo offline (haversine).
GOOGLE_MAPS_API_KEY=

# OAuth 2.0 (pendiente de integrar)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
