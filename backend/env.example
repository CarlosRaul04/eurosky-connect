# Copia este archivo como .env y coloca tus valores reales.
# NUNCA subas el .env real al repositorio.
PORT=3000

# Clave de Google Maps Platform (Maps JavaScript API en el frontend).
# Si se deja vacia, el frontend usa el mapa SVG de respaldo.
GOOGLE_MAPS_API_KEY=

# Google OAuth 2.0 (login). Si CLIENT_ID/SECRET estan vacios, la app corre en
# modo desarrollo (acceso como invitado, rutas protegidas abiertas).
# En Google Cloud Console registra como "URI de redireccion autorizado":
#   http://localhost:3000/api/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
